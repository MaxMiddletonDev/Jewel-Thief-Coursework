<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs230.group29se.jewelthief.Scenes.AchievementsScene.AchievementsController"
      alignment="CENTER"
      spacing="20"
      style="-fx-padding: 20; -fx-background-color: white;">

    <Label text="Achievements" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <content>
            <VBox fx:id="achievementsContainer" spacing="10"/>
        </content>
    </ScrollPane>

    <Button text="Back" onAction="#handleBackClicked" prefWidth="100"/>

</VBox>