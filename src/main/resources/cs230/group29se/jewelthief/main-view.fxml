<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="cs230.group29se.jewelthief.Scenes.MainScene.MainMenuController"
            style="-fx-background-color: #ffffff;">

    <children>

        <VBox spacing="30"
              alignment="CENTER"
              AnchorPane.topAnchor="40"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40"
              AnchorPane.bottomAnchor="40">

            <Label text="Jewel Thief"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #222222;"/>

            <VBox spacing="15" alignment="CENTER">
                <Button fx:id="startButton"
                        text="Play"
                        onAction="#handleStartClicked"
                        prefWidth="160"
                        style="-fx-font-size: 16px;"/>
                <Button fx:id="selectProfileButton"
                        text="Select Profile"
                        onAction="#selectProfileClicked"
                        prefWidth="160"/>
                <Button fx:id="equipablesButton"
                        text="Equipables"
                        onAction="#handleEquipablesClicked"
                        prefWidth="160"/>
                <Button fx:id="achievementsButton"
                        text="Achievements"
                        onAction="#handleAchievementsClicked"
                        prefWidth="160"/>
                <Button fx:id="highScoresButton"
                        text="High Scores"
                        onAction="#handleHighScoresClicked"
                        prefWidth="160"/>
                <Button fx:id="creditsButton"
                        text="Credits"
                        onAction="#handleCreditsClicked"
                        prefWidth="160"/>
                <Button fx:id="quitButton"
                        text="Quit"
                        onAction="#handleQuitClicked"
                        prefWidth="120"/>
            </VBox>

        </VBox>

        <!-- Bottom-left profile display -->
        <VBox spacing="5"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="20"
              alignment="CENTER">

            <!-- Equipped skin image -->
            <ImageView fx:id="equippedSkinImage"
                       fitWidth="80"
                       preserveRatio="true" />

            <!-- Profile name text -->
            <Label fx:id="profileNameLabel"
                   text="Player Name"
                   style="-fx-font-size: 14px; -fx-text-fill: #222222;" />

        </VBox>

    </children>
</AnchorPane>
